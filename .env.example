# frontend/.env.example
# Vercel: add this in Dashboard → Settings → Environment Variables (Production + Preview).
# Value = backend ONLY, e.g. https://beni-back-xxxx.vercel.app (no trailing slash, no /api).
# Change requires a new deploy so Vite picks it up.
#
# Local: .env.development points at localhost; you normally do not edit this file.
VITE_API_BASE_URL=
